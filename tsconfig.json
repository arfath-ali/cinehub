{
  "compilerOptions": {
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",
    "verbatimModuleSyntax": true, 
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "isolatedModules": true,
    "moduleDetection": "force",

    /* Build settings */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true
  }
}
